# Copy this file to `.env` (or `.env.local`) and fill in your OpenAI key.
# These variables are read at dev-server startup by the Vite plugin in
# `server/aiPlugin.ts`. They are NEVER bundled into the client.
#
# If OPENAI_API_KEY is missing or any call fails, the game silently falls
# back to its built-in deterministic logic — no functionality breaks.

OPENAI_API_KEY=sk-...your-key-here...

# Optional: model used for all three endpoints. Defaults to gpt-4o-mini if
# unset. gpt-4o-mini is fast, cheap, and good enough for this game.
# OPENAI_MODEL=gpt-4o-mini